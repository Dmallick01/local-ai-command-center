# .env.example

# Environment variables for Ollama, voice and automation settings, and server configuration.

# Ollama Configuration
OLLAMA_API_KEY=your_ollama_api_key_here

# Voice Configuration
VOICE_LANGUAGE=en-US
VOICE_VOLUME=1.0
VOICE_RATE=1.0

# Browser Automation
BROWSER_TIMEOUT=30
BROWSER_HEADLESS=true

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost
